<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - My ASP.NET Application</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <link rel="stylesheet" href="~/fonts/icomoon/style.css">
    <link rel="stylesheet" href="~/Content/css/bootstrap/bootstrap.css">
    @*<link href="~/Content/bootstrap.min.css" rel="stylesheet" />*@
    @*<link rel="stylesheet" href="~/Content/css/jquery-ui.css">*@
    @*<link rel="stylesheet" href="~/Content/css/owl.carousel.min.css">*@
    @*<link rel="stylesheet" href="~/Content/css/owl.theme.default.min.css">*@
    @*<link rel="stylesheet" href="~/Content/css/jquery.fancybox.min.css">*@
    @*<link rel="stylesheet" href="~/Content/css/bootstrap-datepicker.css">*@
    @*<link rel="stylesheet" href="~/Content/fonts/flaticon/font/flaticon.css">*@
    @*<link rel="stylesheet" href="~/Content/css/aos.css">*@
    <link rel="stylesheet" href="~/Content/css/style.css">
</head>
<body>
    <header class="site-navbar py-4" role="banner" style=" top:0px; background-color: #031735;">
        <div style=" width: 100%; margin-bottom: 10px; margin-top:-15px; background-color: #02122a; ">
            <div class="d-flex align-items-center">
                <nav class="site-navigation position-relative text-right" role="navigation">
                    <ul class="site-menu main-menu js-clone-nav mr-auto d-none d-lg-block">
                        <li><i class="bi bi-facebook"></i></li>
                        <li>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-facebook" viewBox="0 0 16 16">
                                <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951" />
                            </svg>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
        <div class="container">
            <div class="d-flex align-items-center">
                <div class="site-logo">
                    <a href="index.html">
                        <p style="color: #ee1e46 ">آراد</p>
                    </a>
                </div>
                <div>
                    <nav class="site-navigation position-relative text-right" role="navigation">
                        <ul class="site-menu main-menu js-clone-nav mr-auto d-none d-lg-block">
                            <li class="active"><a href="index.html" class="nav-link ">خانه</a></li>
                            <li><a href="matches.html" class="">بازی ها</a></li>
                            <li><a href="players.html" class="nav-link ">بازیکن ها</a></li>
                            <li><a href="blog.html" class="nav-link ">بلاگ</a></li>
                            <li><a href="contact.html" class="nav-link">تماس با ما</a></li>
                        </ul>
                    </nav>
                </div>
                <div class="ml-auto" style="position:absolute;left:10%;">
                    @Html.Partial("_LoginState")
                </div>
            </div>
        </div>
    </header>
    @RenderBody()
</body>
</html>
@*@Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)*@
<script src="~/js/Content/jquery-3.3.1.min.js"></script>
<script src="~/js/Content/jquery-migrate-3.0.1.min.js"></script>
<script src="~/js/Content/jquery-ui.js"></script>
<script src="~/js/Content/popper.min.js"></script>
<script src="~/js/Content/bootstrap.min.js"></script>
<script src="~/js/Content/owl.carousel.min.js"></script>
<script src="~/js/Content/jquery.stellar.min.js"></script>
<script src="~/js/Content/jquery.countdown.min.js"></script>
<script src="~/js/Content/bootstrap-datepicker.min.js"></script>
<script src="~/js/Content/jquery.easing.1.3.js"></script>
<script src="~/js/Content/aos.js"></script>
<script src="~/js/Content/jquery.fancybox.min.js"></script>
<script src="~/js/Content/jquery.sticky.js"></script>
<script src="~/js/Content/jquery.mb.YTPlayer.min.js"></script>
<script src="~/js/Content/main.js"></script>